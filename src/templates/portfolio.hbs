<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{name}} — {{title}}. {{summary}}">
  <title>{{name}} | Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap"
    rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/framer-motion/10.12.16/framer-motion.js"></script>
  <!-- Will use CSS animations instead for simplicity in static export -->

  <style>
    :root {
      /* Color palette — deep navy to violet gradient theme */
      --bg-primary: #0a0a1a;
      --bg-secondary: #111128;
      --bg-tertiary: #1a1a3e;
      --bg-card: rgba(20, 20, 50, 0.6);
      --bg-glass: rgba(255, 255, 255, 0.03);
      --border-glass: rgba(255, 255, 255, 0.08);
      --border-hover: rgba(255, 255, 255, 0.15);

      --text-primary: #f0f0f8;
      --text-secondary: #a0a0c0;
      --text-muted: #6b6b8d;

      --accent-primary: #7c3aed;
      --accent-secondary: #a855f7;
      --accent-tertiary: #c084fc;
      --accent-glow: rgba(124, 58, 237, 0.25);
      --accent-gradient: linear-gradient(135deg, #7c3aed, #a855f7, #c084fc);

      --teal: #2dd4bf;
      --teal-glow: rgba(45, 212, 191, 0.2);
      --amber: #f59e0b;

      /* Typography */
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-display: 'Space Grotesk', 'Inter', sans-serif;

      /* Spacing */
      --section-padding: 120px 0;
      --container-width: 1200px;

      /* Transitions */
      --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      --transition-slow: 0.6s cubic-bezier(0.4, 0, 0.2, 1);

      /* Border radius */
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --radius-xl: 28px;
    }

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: 80px;
    }

    body {
      font-family: var(--font-sans);
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: var(--bg-primary);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--accent-primary);
      border-radius: 3px;
    }

    /* ===== NAVBAR ===== */
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      padding: 16px 0;
      transition: var(--transition-base);
      background: rgba(10, 10, 26, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-glass);
    }

    .navbar-container {
      max-width: var(--container-width);
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .navbar-logo {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-decoration: none;
      letter-spacing: -0.5px;
    }

    .navbar-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }

    .navbar-links a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: var(--transition-fast);
      position: relative;
    }

    .navbar-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--accent-gradient);
      transition: var(--transition-base);
    }

    .navbar-links a:hover {
      color: var(--text-primary);
    }

    .navbar-links a:hover::after {
      width: 100%;
    }

    /* ===== SECTION COMMON ===== */
    .section {
      padding: var(--section-padding);
      position: relative;
    }

    .container {
      max-width: var(--container-width);
      margin: 0 auto;
      padding: 0 24px;
    }

    .section-label {
      font-family: var(--font-display);
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--accent-secondary);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-label::before {
      content: '';
      display: block;
      width: 24px;
      height: 2px;
      background: var(--accent-gradient);
      border-radius: 1px;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 16px;
      letter-spacing: -1px;
      line-height: 1.2;
    }

    .section-subtitle {
      font-size: 1.05rem;
      color: var(--text-secondary);
      max-width: 600px;
      line-height: 1.7;
    }

    /* ===== HERO ===== */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      position: relative;
      overflow: hidden;
      padding-top: 80px;
    }

    .hero-bg-gradient {
      position: absolute;
      top: -30%;
      right: -20%;
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, var(--accent-glow), transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .hero-bg-gradient-2 {
      position: absolute;
      bottom: -20%;
      left: -10%;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, var(--teal-glow), transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .hero-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 16px;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 100px;
      font-size: 0.85rem;
      color: var(--teal);
      font-weight: 500;
    }

    .hero-badge-dot {
      width: 8px;
      height: 8px;
      background: var(--teal);
      border-radius: 50%;
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.5;
        transform: scale(0.8);
      }
    }

    .hero-name {
      font-family: var(--font-display);
      font-size: clamp(3rem, 6vw, 5rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -2px;
    }

    .hero-name-gradient {
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-title {
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      color: var(--text-secondary);
      font-weight: 400;
      line-height: 1.6;
      max-width: 700px;
      margin: 0 auto;
    }

    .hero-cta-group {
      display: flex;
      gap: 16px;
      padding-top: 16px;
      justify-content: center;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      background: var(--accent-gradient);
      color: white;
      border: none;
      border-radius: 100px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: var(--transition-base);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px var(--accent-glow);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      background: transparent;
      color: var(--text-primary);
      border: 1px solid var(--border-glass);
      border-radius: 100px;
      font-size: 0.95rem;
      font-weight: 500;
      cursor: pointer;
      transition: var(--transition-base);
      text-decoration: none;
    }

    .btn-secondary:hover {
      border-color: var(--accent-secondary);
      background: var(--bg-glass);
      transform: translateY(-2px);
    }

    /* ===== ABOUT ===== */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
      margin-top: 48px;
    }

    .about-text h3 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 20px;
    }

    .about-text p {
      color: var(--text-secondary);
      margin-bottom: 16px;
      font-size: 1.05rem;
      line-height: 1.8;
    }

    .about-highlights {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 16px;
      margin-top: 32px;
    }

    .about-highlight-card {
      padding: 20px;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius-md);
      transition: var(--transition-base);
    }

    .about-highlight-card:hover {
      border-color: var(--border-hover);
      background: rgba(255, 255, 255, 0.05);
    }

    .about-highlight-card h4 {
      font-size: 0.95rem;
      font-weight: 600;
      margin-bottom: 4px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .about-highlight-card .icon {
      color: var(--accent-secondary);
    }

    .about-highlight-card p {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 0;
    }

    /* ===== EXPERIENCE ===== */
    #experience {
      background: var(--bg-secondary);
    }

    .experience-timeline {
      margin-top: 48px;
      position: relative;
    }

    .experience-timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--accent-primary), var(--teal), transparent);
    }

    .experience-item {
      padding-left: 48px;
      margin-bottom: 48px;
      position: relative;
    }

    .experience-item::before {
      content: '';
      position: absolute;
      left: -5px;
      top: 6px;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--accent-primary);
      border: 3px solid var(--bg-secondary);
      box-shadow: 0 0 12px var(--accent-glow);
    }

    .experience-card {
      background: var(--bg-card);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius-lg);
      padding: 32px;
      transition: var(--transition-base);
    }

    .experience-card:hover {
      border-color: var(--border-hover);
      transform: translateX(4px);
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.2);
    }

    .experience-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .experience-role {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 700;
    }

    .experience-company {
      font-size: 1rem;
      color: var(--accent-tertiary);
      font-weight: 500;
      margin-top: 4px;
    }

    .experience-meta {
      text-align: right;
    }

    .experience-date {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .experience-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .experience-bullets li {
      font-size: 0.95rem;
      color: var(--text-secondary);
      line-height: 1.7;
      padding-left: 20px;
      position: relative;
    }

    .experience-bullets li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: var(--accent-secondary);
      font-weight: 600;
    }

    /* ===== PROJECTS ===== */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 24px;
      margin-top: 48px;
    }

    .project-card {
      padding: 32px;
      background: var(--bg-card);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius-lg);
      transition: var(--transition-base);
      display: flex;
      flex-direction: column;
    }

    .project-card:hover {
      border-color: var(--accent-secondary);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
    }

    .project-icon {
      width: 44px;
      height: 44px;
      background: rgba(124, 58, 237, 0.15);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent-secondary);
      margin-bottom: 20px;
    }

    .project-title {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .project-description {
      color: var(--text-secondary);
      font-size: 0.95rem;
      margin-bottom: 24px;
      flex-grow: 1;
    }

    .project-tech {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .project-tech-tag {
      padding: 4px 12px;
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-radius: 100px;
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* ===== SKILLS ===== */
    #skills {
      background: var(--bg-secondary);
    }

    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 48px;
    }

    .skill-tag-lg {
      padding: 12px 24px;
      background: var(--bg-card);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius-sm);
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-primary);
      transition: var(--transition-base);
    }

    .skill-tag-lg:hover {
      border-color: var(--teal);
      background: var(--teal-glow);
      transform: translateY(-2px);
    }

    /* ===== CONTACT ===== */
    .contact-section {
      text-align: center;
    }

    .contact-links {
      display: flex;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: 48px;
    }

    .contact-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 24px;
      background: var(--bg-card);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      transition: var(--transition-base);
    }

    .contact-link:hover {
      border-color: var(--accent-secondary);
      background: rgba(255, 255, 255, 0.05);
      transform: translateY(-2px);
    }

    footer {
      padding: 32px;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.85rem;
      border-top: 1px solid var(--border-glass);
      background: var(--bg-primary);
    }

    @media (max-width: 768px) {
      .navbar-links {
        display: none;
      }

      .section {
        padding: 80px 0;
      }

      .hero-container {
        padding-top: 40px;
      }

      .hero-name {
        font-size: 3rem;
      }

      .hero-cta-group {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 12px;
        width: 100%;
        justify-content: center;
      }

      .btn-primary,
      .btn-secondary {
        padding: 10px 20px;
        font-size: 0.85rem;
        width: auto;
        max-width: none;
      }

      .btn-primary svg {
        width: 16px;
        height: 16px;
      }

      .experience-item {
        padding-left: 24px;
      }

      .experience-card {
        padding: 20px;
      }
    }

    /* Simple Intro Animations */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      animation: fadeUpAnim 0.8s forwards cubic-bezier(0.22, 1, 0.36, 1);
    }

    .delay-1 {
      animation-delay: 0.1s;
    }

    .delay-2 {
      animation-delay: 0.2s;
    }

    .delay-3 {
      animation-delay: 0.3s;
    }

    @keyframes fadeUpAnim {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>

<body>

  <nav class="navbar">
    <div class="navbar-container">
      <a href="#" class="navbar-logo">{{#if parsedData.name}}{{parsedData.name}}{{else}}Portfolio{{/if}}</a>
      <ul class="navbar-links">
        <li><a href="#about">About</a></li>
        {{#if experienceNarrative.length}}<li><a href="#experience">Experience</a></li>{{/if}}
        {{#if projects.length}}<li><a href="#projects">Projects</a></li>{{/if}}
        {{#if skills.length}}<li><a href="#skills">Skills</a></li>{{/if}}
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero-bg-gradient"></div>
    <div class="hero-bg-gradient-2"></div>

    <div class="hero-container">
      <div class="hero-badge fade-up">
        <span class="hero-badge-dot"></span>
        {{title}}
      </div>

      <h1 class="hero-name fade-up delay-1">
        Hi, I'm <br /><span class="hero-name-gradient">{{name}}</span>
      </h1>

      <p class="hero-title fade-up delay-2">
        {{headline}}
      </p>

      <div class="hero-cta-group fade-up delay-3">
        <a href="#contact" class="btn-primary">
          Get In Touch <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
        <a href="#about" class="btn-secondary">
          View My Work
        </a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-label">About</div>
      <h2 class="section-title">Turning complex problems into <br />scalable solutions</h2>
      <div class="about-grid">
        <div class="about-text">
          <p>{{bio}}</p>
          <p>{{summary}}</p>

          <div class="about-highlights">
            {{#if location}}
            <div class="about-highlight-card">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
                <path
                  d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <h4>Location</h4>
              <p>{{location}}</p>
            </div>
            {{/if}}
            {{#if email}}
            <div class="about-highlight-card">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              <h4>Email</h4>
              <p>{{email}}</p>
            </div>
            {{/if}}
            {{#if linkedin}}
            <div class="about-highlight-card">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect width="4" height="12" x="2" y="9" />
                <circle cx="4" cy="4" r="2" />
              </svg>
              <h4>LinkedIn</h4>
              <p><a href="https://{{linkedin}}" target="_blank"
                  style="color:var(--text-muted);text-decoration:none;">{{linkedin}}</a></p>
            </div>
            {{/if}}
            {{#if github}}
            <div class="about-highlight-card">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
                <path
                  d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
              <h4>GitHub</h4>
              <p><a href="https://{{github}}" target="_blank"
                  style="color:var(--text-muted);text-decoration:none;">{{github}}</a></p>
            </div>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  {{#if experienceNarrative.length}}
  <section class="section" id="experience">
    <div class="container">
      <div class="section-label">Experience</div>
      <h2 class="section-title">Where I've made an impact</h2>

      <div class="experience-timeline">
        {{#each experienceNarrative}}
        <div class="experience-item">
          <div class="experience-card">
            <div class="experience-header">
              <div>
                <div class="experience-role">{{this.role}}</div>
                <div class="experience-company">{{this.company}}</div>
              </div>
              <div class="experience-meta">
                <div class="experience-date">{{this.startDate}} — {{this.endDate}}</div>
              </div>
            </div>
            {{#if this.description}}
            <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">
              {{this.description}}</p>
            {{/if}}
            <ul class="experience-bullets">
              {{#each this.highlights}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  <!-- PROJECTS -->
  {{#if projects.length}}
  <section class="section" id="projects">
    <div class="container">
      <div class="section-label">Projects</div>
      <h2 class="section-title">Things I've built</h2>

      <div class="projects-grid">
        {{#each projects}}
        <div class="project-card">
          <div class="project-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
            </svg>
          </div>
          <div class="project-title">{{this.title}}</div>
          <div class="project-description">{{this.description}}</div>
          {{#if this.technologies}}
          <div class="project-tech">
            {{#each this.technologies}}
            <span class="project-tech-tag">{{this}}</span>
            {{/each}}
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  <!-- SKILLS -->
  {{#if skills.length}}
  <section class="section" id="skills">
    <div class="container">
      <div class="section-label">Skills</div>
      <h2 class="section-title">My technical toolkit</h2>
      <div class="skills-grid">
        {{#each skills}}
        <span class="skill-tag-lg">{{#if this.name}}{{this.name}}{{else}}{{this}}{{/if}}</span>
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  <!-- CONTACT -->
  <section class="section contact-section" id="contact">
    <div class="container">
      <div class="section-label" style="justify-content:center;">Contact</div>
      <h2 class="section-title">Let's connect</h2>
      <p class="section-subtitle" style="margin: 0 auto;">I'm always open to new opportunities, collaborations, or just
        a friendly chat about tech.</p>

      <div class="contact-links">
        {{#if email}}
        <a href="mailto:{{email}}" class="contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg> {{email}}
        </a>
        {{/if}}
        {{#if linkedin}}
        <a href="https://{{linkedin}}" target="_blank" class="contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect width="4" height="12" x="2" y="9" />
            <circle cx="4" cy="4" r="2" />
          </svg> LinkedIn
        </a>
        {{/if}}
        {{#if github}}
        <a href="https://{{github}}" target="_blank" class="contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg> GitHub
        </a>
        {{/if}}
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p>© 2026 {{name}}. <a href="#" style="color:var(--text-muted);text-decoration:none;">Generated with
          Portfoliogy</a></p>
    </div>
  </footer>

</body>

</html>